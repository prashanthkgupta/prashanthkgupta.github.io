---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Prashant Kumar Gupta — Software Engineer',
  description = 'Senior Software Engineer building high-scale distributed systems at Expedia Group. 7+ years of experience in microservice architecture, performance engineering, and distributed systems.',
} = Astro.props;

const siteUrl = 'https://prashanthkgupta.github.io';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Prashant Kumar Gupta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <noscript>
      <style>
        .animate-on-scroll {
          opacity: 1 !important;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-bg text-text min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only fixed top-4 left-4 z-[100] rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-bg focus:outline-none"
    >
      Skip to content
    </a>
    <slot />
    <script>
      const animObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = parseInt(el.dataset.delay || '0', 10);
              if (delay > 0) {
                setTimeout(() => el.classList.add('visible'), delay);
              } else {
                el.classList.add('visible');
              }
              animObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        animObserver.observe(el);
      });

      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('.nav-link');

      const spyObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              navLinks.forEach((link) => {
                const el = link as HTMLElement;
                if (el.dataset.section === entry.target.id) {
                  el.classList.add('text-accent', 'nav-active');
                  el.classList.remove('text-text-muted');
                } else {
                  el.classList.remove('text-accent', 'nav-active');
                  el.classList.add('text-text-muted');
                }
              });
            }
          });
        },
        { threshold: 0.2, rootMargin: '-80px 0px -50% 0px' }
      );

      sections.forEach((section) => spyObserver.observe(section));
    </script>
  </body>
</html>
