---
import { personal } from '../data/resume';
---

<section id="about" class="px-6 py-24">
  <div class="animate-on-scroll mx-auto max-w-4xl">
    <h2 class="mb-2 text-sm font-medium tracking-widest text-accent uppercase">
      About
    </h2>
    <h3 class="mb-8 text-3xl font-bold md:text-4xl">Who I Am</h3>

    <div class="space-y-4 text-lg leading-relaxed text-text-muted">
      <p>
        I'm a <span class="text-text font-medium">Senior Software Engineer</span
        > at <span class="text-accent font-medium">{personal.company}</span>,
        working on the Order Management System that powers bookings across
        Expedia's global platform.
      </p>
      <p>
        With <span class="text-text font-medium">7+ years</span> of experience
        across companies like <span class="text-text font-medium"
          >MakeMyTrip</span
        > and <span class="text-text font-medium">Surewaves MediaTech</span>,
        I've built and scaled distributed systems handling millions of
        transactions. My work spans from designing microservice architectures
        and optimizing Elasticsearch clusters to consolidating booking engines
        across major travel platforms.
      </p>
      <p>
        I'm passionate about <span class="text-text font-medium"
          >performance engineering</span
        >, <span class="text-text font-medium">clean system design</span>,
        and building tools that make engineering teams move faster.
      </p>
    </div>
  </div>
</section>
