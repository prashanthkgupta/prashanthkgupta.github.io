---
import { personal } from '../data/resume';
import Icon from './Icon.astro';
---

<section id="contact" class="px-6 py-24">
  <div class="animate-on-scroll mx-auto max-w-2xl text-center">
    <h2 class="mb-2 text-sm font-medium tracking-widest text-accent uppercase">
      Contact
    </h2>
    <h3 class="mb-6 text-3xl font-bold md:text-4xl">Let's Connect</h3>
    <p class="mb-10 text-lg text-text-muted">
      I'm always open to discussing new opportunities, interesting projects, or
      just having a good technical conversation.
    </p>

    <a
      href={`mailto:${personal.email}`}
      class="inline-flex items-center gap-2 rounded-lg bg-accent px-8 py-3.5 text-sm font-semibold text-bg transition-colors hover:bg-accent-dim"
    >
      <Icon name="email" class="h-4 w-4" />
      Say Hello
    </a>

    <div class="mt-10 flex items-center justify-center gap-6">
      <a
        href={personal.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted transition-colors hover:text-accent"
        aria-label="GitHub"
      >
        <Icon name="github" class="h-5 w-5" />
      </a>
      <a
        href={personal.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted transition-colors hover:text-accent"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin" class="h-5 w-5" />
      </a>
      <a
        href={personal.socials.leetcode}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted transition-colors hover:text-accent"
        aria-label="LeetCode"
      >
        <Icon name="leetcode" class="h-5 w-5" />
      </a>
    </div>
  </div>
</section>
