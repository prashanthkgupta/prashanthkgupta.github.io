---
import { education } from '../data/resume';
---

<section id="education" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <div class="animate-on-scroll">
      <h2
        class="mb-2 text-sm font-medium tracking-widest text-accent uppercase"
      >
        Education
      </h2>
      <h3 class="mb-12 text-3xl font-bold md:text-4xl">Academic Background</h3>
    </div>

    <div class="space-y-6">
      {
        education.map((edu, i) => (
          <div
            class="animate-on-scroll rounded-xl border border-border bg-bg-card p-8 transition-colors hover:border-accent/30 hover:bg-bg-card-hover"
            data-delay={i * 100}
          >
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h4 class="text-lg font-bold text-text">{edu.degree}</h4>
                <p class="text-text-muted">{edu.university}</p>
                <p class="text-sm text-text-muted">{edu.location}</p>
              </div>
              <div class="shrink-0 text-left sm:text-right">
                <span class="block text-sm font-medium text-accent">
                  {edu.period}
                </span>
                <span class="text-sm text-text-muted">{edu.score}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
