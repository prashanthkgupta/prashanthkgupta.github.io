---
import { experience } from '../data/resume';
---

<section id="experience" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <div class="animate-on-scroll">
      <h2
        class="mb-2 text-sm font-medium tracking-widest text-accent uppercase"
      >
        Experience
      </h2>
      <h3 class="mb-12 text-3xl font-bold md:text-4xl">Where I've Worked</h3>
    </div>

    <div class="relative">
      <div
        class="absolute top-0 bottom-0 left-0 w-px bg-border md:left-1/2 md:-translate-x-px"
      >
      </div>

      {
        experience.map((job, i) => (
          <div
            class={`animate-on-scroll relative mb-12 flex flex-col md:flex-row ${i % 2 === 0 ? 'md:flex-row-reverse' : ''}`}
            style={`animation-delay: ${i * 100}ms`}
          >
            <div class="absolute left-0 top-2 h-3 w-3 rounded-full border-2 border-accent bg-bg md:left-1/2 md:-translate-x-1.5" />

            <div
              class={`ml-8 md:ml-0 md:w-1/2 ${i % 2 === 0 ? 'md:pl-12' : 'md:pr-12 md:text-right'}`}
            >
              <div class="rounded-xl border border-border bg-bg-card p-6 transition-colors hover:border-accent/30 hover:bg-bg-card-hover">
                <span class="mb-1 block text-xs font-medium text-accent">
                  {job.period}
                </span>
                <h4 class="text-lg font-bold text-text">{job.role}</h4>
                <p class="mb-4 text-sm text-text-muted">{job.company}</p>
                <ul
                  class={`space-y-2 text-sm leading-relaxed text-text-muted ${i % 2 === 0 ? '' : 'md:text-left'}`}
                >
                  {job.highlights.map((h) => (
                    <li class="flex gap-2">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
