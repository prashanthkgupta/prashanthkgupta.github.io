  >
    <p>&copy; {year} Prashant Kumar Gupta. All rights reserved.</p>
    <p>
      Built with <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline">Astro</a
      > &
      <a
        href="https://tailwindcss.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline">Tailwind CSS</a
      >
    </p>
  </div>
</footer>
